# Зависимости — ставятся через npm install / pip install, в репозиторий не нужны
node_modules/
__pycache__/
*.pyc

# Личные данные: пароли ЯБ, сохранённые сессии/куки, реальные страны/города,
# загруженные картинки, скриншоты, логи, отчёты — это данные, не код.
users-data/

# Старая корневая структура данных (до users-data/{project}/) — тоже реальные
# куки/сессии/логи/задачи, не код. Не должны попадать в репозиторий.
/session/
/logs/
/tasks/
/reports/
/screenshots/

# Локальные логи
*.log

# Секреты Streamlit (пароли) — никогда не коммитить
.streamlit/secrets.toml

# Локальные настройки Claude Code — machine-specific, не для общего репозитория
.claude/settings.local.json
